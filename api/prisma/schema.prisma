generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Signal {
  id        Int      @id @default(autoincrement())
  symbol    String
  provider  String?
  signal    String
  score     Float?   
  metadata  Json?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AccessLog {
  id        Int      @id @default(autoincrement())
  event     String
  path      String?
  ip        String?
  userAgent String?
  fingerprint String?
  details   Json?
  createdAt DateTime @default(now())
}
